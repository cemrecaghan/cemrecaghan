      "cell_type": "code",
      "source": [
        "\n",
        "import numpy as np\n",
        "from scipy.optimize import linprog\n",
        "\n",
        "Y = np.array([\n",
        "[1.35,60],\n",
        "[1.1,6],\n",
        "[1.27,45],\n",
        "[0.66,1.5],\n",
        "[0.05,50],\n",
        "[0.3,1],\n",
        "[1,5],\n",
        "[1,15],\n",
        "[1.1,10],\n",
        "[1,6],\n",
        "[0.9,30],\n",
        "[0.15,13.6],\n",
        "[1.2,10],\n",
        "[1.2,30],\n",
        "[1,47]\n",
        "])\n",
        "\n",
        "X = np.array([\n",
        "[7.2,0.15],\n",
        "[4.8,0.05],\n",
        "[5,1.27],\n",
        "[7.2,0.025],\n",
        "[9.6,0.25],\n",
        "[1.07,0.1],\n",
        "[1.76,0.1],\n",
        "[3.2,0.1],\n",
        "[6.72,0.2],\n",
        "[2.4,0.05],\n",
        "[2.88,0.5],\n",
        "[6.9,1],\n",
        "[3.2,0.05],\n",
        "[4,0.05],\n",
        "[3.68,1]\n",
        "])\n",
        "\n",
        "n = 15\n",
        "scores = []\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "for k in range(n):\n",
        "  c = [-Y[k,0], -Y[k,1], 0, 0]\n",
        "\n",
        "    A_eq = [[0,0,X[k,0],X[k,1]]]\n",
        "    b_eq = [1]\n",
        "\n",
        "    A_ub = []\n",
        "    b_ub = []\n",
        "\n",
        "    for j in range(n):\n",
        "        A_ub.append([Y[j,0],Y[j,1],-X[j,0],-X[j,1]])\n",
        "        b_ub.append(0)\n",
        "\n",
        "    bounds = [(0,None),(0,None),(0,None),(0,None)]\n",
        "\n",
        "    res = linprog(c,A_ub=A_ub,b_ub=b_ub,A_eq=A_eq,b_eq=b_eq,bounds=bounds)\n",
        "\n",
        "    scores.append(-res.fun)\n",
        "\n",
        "for i,s in enumerate(scores):\n",
        "    print(\"Birim\",i+1,\"Etkinlik Skoru:\",round(s,4))"
